{
  "name": "component-ai",
  "private": true,
  "version": "1.0.0",
  "description": "Monorepo: React and Vue component libraries (Tailwind CSS)",
  "license": "ISC",
  "workspaces": ["packages/*", "apps/*"],
  "devDependencies": {
    "@storybook/addon-essentials": "^8.6.0",
    "@storybook/react-vite": "^8.6.0",
    "@storybook/vue3-vite": "^8.6.0",
    "storybook": "^8.6.0"
  },
  "overrides": {
    "vite": "^8.0.10"
  },
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "build:react": "npm run build -w @component-ai/react-ui",
    "build:vue": "npm run build -w @component-ai/vue-ui",
    "build:grid-core": "npm run build -w @component-ai/grid-core",
    "build:ai-chat": "npm run build -w @component-ai/ai-chat",
    "test:grid-core": "npm run test -w @component-ai/grid-core",
    "test:ai-chat": "npm run test -w @component-ai/ai-chat",
    "storybook:react": "npm run storybook -w @component-ai/storybook-react",
    "storybook:vue": "npm run storybook -w @component-ai/storybook-vue",
    "build-storybook:react": "npm run build-storybook -w @component-ai/storybook-react",
    "build-storybook:vue": "npm run build-storybook -w @component-ai/storybook-vue"
  }
}
